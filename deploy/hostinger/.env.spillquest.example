# ═══════════════════════════════════════════════════════════════════════════
# SpillQuest (spillquest.com) — VPS Environment
# Copy to /opt/shre/envs/.env.spillquest and fill in values
# Used by: docker-compose.spillquest.yml
# ═══════════════════════════════════════════════════════════════════════════

# ── AI (required for Spill card generation) ──────────────────────────────
OPENAI_API_KEY=CHANGE_ME_BEFORE_DEPLOY
OPENAI_MODEL=gpt-4.1-mini

# ── Optional: Use local Ollama instead of OpenAI ────────────────────────
OLLAMA_ENABLED=false
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2

# ── Insights API database (optional — only if insights-api is used) ─────
# INSIGHTS_DB_HOST=
# INSIGHTS_DB_PORT=5432
# INSIGHTS_DB_USER=
# INSIGHTS_DB_PASSWORD=
# INSIGHTS_DB_NAME=
