# ═══════════════════════════════════════════════════════════════════════════
# Shre Core Services — VPS Environment
# Copy to /opt/shre/envs/.env.shre-core and fill in values
# Used by: docker-compose.aros-retail.yml
# ═══════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_DB=shre
POSTGRES_USER=rapidnir
POSTGRES_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_BEFORE_DEPLOY

# ── Auth ──────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=CHANGE_ME_32_CHARS_MINIMUM
AUTH_SIGNING_KEY=CHANGE_ME_BEFORE_DEPLOY

# ── AI Model Keys ─────────────────────────────────────────────────────��──
# At minimum ONE of these, or leave all blank for Ollama-only
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=

# ── Service Tokens (inter-service auth) ──────────────────────────────────
ROUTER_ADMIN_TOKEN=CHANGE_ME_BEFORE_DEPLOY
SHRE_FLEET_TOKEN=CHANGE_ME_BEFORE_DEPLOY
SHRE_TASKS_TOKEN=CHANGE_ME_BEFORE_DEPLOY

# ── External Ports (host bindings, change if conflicts) ──────────────────
POSTGRES_EXTERNAL_PORT=5433
REDIS_EXTERNAL_PORT=6379
QDRANT_EXTERNAL_PORT=6333
OLLAMA_EXTERNAL_PORT=11434

# ── Production ────────────────────────────────────────────────────────────
NODE_ENV=production
SHRE_TIER=standard
