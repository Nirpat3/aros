# AROS Retail Intelligence — Environment Configuration
# Single command: docker compose -f docker-compose.aros-retail.yml up -d
#
# Copy this file to .env.aros-retail and fill in the required values.
# cp .env.aros-retail.example .env.aros-retail

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=rapidnir
POSTGRES_PASSWORD=rapid@nir
POSTGRES_DB=aros_retail
# POSTGRES_EXTERNAL_PORT=5433

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=shrepassword
# REDIS_EXTERNAL_PORT=6379

# ─── Vector DB ───────────────────────────────────────────────────────────────
# QDRANT_EXTERNAL_PORT=6333

# ─── Local AI (Ollama) ──────────────────────────────────────────────────────
# Ollama runs as a local AI fallback. No API key needed.
# OLLAMA_EXTERNAL_PORT=11434

# ─── Cloud AI Keys (optional — Ollama is the fallback) ──────────────────────
# If provided, shre-router will prefer cloud models for higher quality.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SIGNING_KEY=

# ─── Router ──────────────────────────────────────────────────────────────────
# Admin token for shre-router management endpoints.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROUTER_ADMIN_TOKEN=

# ─── AROS Platform ──────────────────────────────────────────────────────────
# Secret for session signing in the AROS web frontend.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AROS_SECRET=changeme-in-production

# ─── Whitelabel ──────────────────────────────────────────────────────────────
WHITELABEL=aros-retail-intelligence
SHRE_TIER=standard
NODE_ENV=production
