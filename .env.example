# AROS Platform Environment
NODE_ENV=production

# Auth Provider: "aros" (local), "shre" (delegate), "supabase" (hosted)
AROS_AUTH_PROVIDER=supabase

# Supabase (required when AROS_AUTH_PROVIDER=supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe Billing
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# AROS Local Auth (only when AROS_AUTH_PROVIDER=aros)
AROS_SECRET=change-me-to-random-64-chars

# Shre Integration (optional)
SHRE_ENDPOINT=https://api.nirtek.net
SHRE_API_KEY=

# License
AROS_LICENSE_KEY=

# Domain
AROS_DOMAIN=aros.nirtek.net
