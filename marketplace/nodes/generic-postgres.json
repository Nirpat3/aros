{
  "id": "com.nirlab.generic-postgres",
  "name": "PostgreSQL Connector",
  "version": "1.0.0",
  "description": "Connect AROS to any PostgreSQL database. Run queries, sync tables, and make your data available for agent context. Works with self-hosted Postgres, Supabase, Neon, Railway, and more.",
  "category": "database",
  "author": "Nirlab Inc",
  "registry": "https://registry.mib007.io",
  "packageName": "@aros/connector-postgres",
  "capabilities": [
    "data-fetch",
    "local-sync",
    "agent-context",
    "parameterized-queries"
  ],
  "pricing": {
    "model": "free"
  },
  "requiredPlatformVersion": "0.2.0",
  "publishedAt": "2026-03-18T00:00:00Z",
  "updatedAt": "2026-03-18T00:00:00Z",
  "status": "live",
  "configSchema": {
    "host": {
      "type": "string",
      "required": true,
      "label": "Host"
    },
    "port": {
      "type": "number",
      "required": true,
      "label": "Port",
      "default": 5432
    },
    "database": {
      "type": "string",
      "required": true,
      "label": "Database Name"
    },
    "username": {
      "type": "string",
      "required": true,
      "label": "Username"
    },
    "password": {
      "type": "string",
      "required": true,
      "label": "Password",
      "secret": true
    },
    "ssl": {
      "type": "boolean",
      "default": false,
      "label": "Use SSL"
    }
  }
}
