{
  "platform": {
    "name": "AROS",
    "version": "0.3.0",
    "description": "Agentic Retail Operating System"
  },
  "core": {
    "source": "mib007",
    "version": "1.0.0",
    "uiVersion": "1.0.0",
    "autoUpdate": true,
    "updateFeed": "https://registry.mib007.io/releases",
    "channel": "stable"
  },
  "agent": {
    "name": "AROS",
    "model": "gpt-4o",
    "role": "platform-driver",
    "description": "AROS AI is the platform driver — identity, control, and conversation unified."
  },
  "auth": {
    "provider": "aros",
    "note": "Provider can be 'aros' (local file-based), 'shre' (delegate to Shre AI), or 'supabase' (hosted Supabase Auth)"
  },
  "shre": {
    "enabled": true,
    "endpoint": "",
    "fallback": "local",
    "description": "Shre is an optional backend plugin. Set enabled:false for fully standalone deployment."
  },
  "supabase": {
    "enabled": false,
    "note": "Set to true and provide env vars for hosted deployment"
  },
  "whitelabel": {
    "active": "default",
    "customizable": true
  },
  "marketplace": {
    "registryUrl": "https://registry.mib007.io/marketplace",
    "autoSync": true
  },
  "licensing": {
    "tier": "free",
    "maxUsers": 1,
    "whitelabel": false,
    "licenseKey": "",
    "expiresAt": null
  },
  "models": {
    "provider": "mib007",
    "metered": true,
    "byom": {
      "enabled": false,
      "provider": "",
      "apiKey": "",
      "model": "",
      "endpoint": ""
    }
  },
  "updates": {
    "core": {
      "policy": "notify",
      "channel": "stable",
      "autoApplyPatch": true,
      "autoApplyMinor": false,
      "requireManualMajor": true
    },
    "ui": {
      "policy": "notify",
      "ignoreIfWhitelabeled": true,
      "previewBeforeApply": true
    },
    "checkIntervalMinutes": 30,
    "webhookOnUpdate": ""
  }
}
